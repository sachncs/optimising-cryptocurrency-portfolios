include LICENSE
include README.md
include CHANGELOG.md
include pyproject.toml

recursive-exclude * __pycache__
recursive-exclude * *.py[cod]
recursive-exclude * *.so
recursive-exclude * .pytest_cache
recursive-exclude * .mypy_cache
recursive-exclude * .ruff_cache
recursive-exclude * .coverage*
recursive-exclude * htmlcov
recursive-exclude * tests
recursive-exclude * docs
recursive-exclude * outputs
recursive-exclude * runs
recursive-exclude * .github
recursive-exclude * Makefile
recursive-exclude * .editorconfig
recursive-exclude * .gitattributes
recursive-exclude * .gitignore
recursive-exclude * .pre-commit-config.yaml
recursive-exclude * *.yml
recursive-exclude * *.yaml